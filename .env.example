# MongoDB (required)
MONGODB_URI=mongodb://127.0.0.1:27017/surgemind

# JWT secret (change in production)
JWT_SECRET=your-super-secret-jwt-key

# Google Gemini API (optional — uses smart fallback plans without it)
GEMINI_API_KEY=

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# React frontend (create frontend/.env)
# REACT_APP_API_URL=http://localhost:3001
